# ─── API ──────────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000

# ─── App ──────────────────────────────────────────────────────────────────────
VITE_APP_NAME=Divya Foods
VITE_APP_ENV=development

# ─── Razorpay (public key only — never put secret key here) ──────────────────
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id

# ─── Google Maps (optional) ───────────────────────────────────────────────────
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ─── Web Push (VAPID public key — required for browser push notifications) ────
# Must match the VAPID_PUBLIC_KEY configured on the backend.
VITE_VAPID_PUBLIC_KEY=

# ─── Error tracking (optional — leave blank to disable) ───────────────────────
VITE_SENTRY_DSN=
