{
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "https://divya-foods-api-production-9380.up.railway.app/sitemap.xml" },
    { "source": "/((?!sw\\.js|registerSW\\.js|manifest\\.webmanifest|workbox-).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/(.*\\.webmanifest)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options",         "value": "DENY" },
        { "key": "X-Content-Type-Options",   "value": "nosniff" },
        { "key": "Referrer-Policy",          "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",       "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security","value": "max-age=63072000; includeSubDomains; preload" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://*.razorpay.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https://res.cloudinary.com https://*.razorpay.com; connect-src 'self' https://*.railway.app https://*.up.railway.app https://*.razorpay.com; font-src 'self' https://fonts.gstatic.com; frame-src https://*.razorpay.com; worker-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self';"
        }
      ]
    }
  ]
}
